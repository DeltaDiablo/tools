  "version": "0.2.0",
  "configurations": [
    {
      "name": "messageInterpreterViewPanel Debug",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/messageInterpreterViewPanel.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "setupCommands": [
        {
          "description": "Enable pretty-printing for gdb",
          "text": "-enable-pretty-printing",
          "ignoreFailures": false
        }
      ],
      "windows": {
        "miDebuggerPath": "C:/raylib/w64devkit/bin/gdb.exe"
      },
      "osx": {
        "MIMode": "lldb"
      },
      "linux": {
        "miDebuggerPath": "/usr/bin/gdb"
      },
      "preLaunchTask": "build messageInterpreterViewPanel debug"
    },
    {
      "name": "messageInterpreterViewPanel Run",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/messageInterpreterViewPanel.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "windows": {
        "miDebuggerPath": "C:/raylib/w64devkit/bin/gdb.exe"
      },
      "osx": {
        "MIMode": "lldb"
      },
      "linux": {
        "miDebuggerPath": "/usr/bin/gdb"
      },
      "preLaunchTask": "build messageInterpreterViewPanel release"
    }
  ]
}
